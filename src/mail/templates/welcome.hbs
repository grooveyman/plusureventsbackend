{{! src/mail/templates/welcome.hbs }}
<!DOCTYPE html>
<html>
  <head>
    <style>
      body { font-family: Arial, sans-serif; }
      .container { padding: 20px; max-width: 600px; margin: 0 auto; }
      .header { background-color: #4CAF50; color: white; padding: 10px; text-align: center; }
      .content { padding: 20px; }
      .footer { text-align: center; font-size: 12px; color: #aaa; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Welcome!</h1>
      </div>
      <div class="content">
        <p>Hi {{name}},</p>
        <p>Thank you for registering. We're glad to have you!</p>
      </div>
      <div class="footer">
        <p>© 2024 Your App. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>